{
  "name": "nexus-eval-atbench",
  "version": "0.1.0",
  "description": "Atbench (agent-trajectory safety benchmark) evaluation harness for nexus-agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nexus-eval-atbench": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nexus-agents",
    "nexus-agents-eval",
    "benchmark",
    "evaluation",
    "atbench",
    "agent-safety",
    "trajectory-safety"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=22.0.0"
  },
  "files": [
    "dist/"
  ],
  "dependencies": {
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "nexus-agents": ">=2.33.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "nexus-agents": "^2.33.1",
    "typescript": "^5.9.0",
    "vitest": "^4.0.0"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
